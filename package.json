{
  "name": "tabminal",
  "version": "2.0.14",
  "description": "A modern, persistent web terminal with multi-tab support and real-time system monitoring.",
  "type": "module",
  "bin": {
    "tabminal": "./src/server.mjs"
  },
  "main": "src/server.mjs",
  "scripts": {
    "start": "node src/server.mjs",
    "dev": "node --watch src/server.mjs",
    "build": "node build.mjs",
    "test": "node --test",
    "updep": "npx npm-check-updates -u && npm install",
    "test:watch": "node --test --watch",
    "lint": "eslint ."
  },
  "keywords": [
    "terminal",
    "web-terminal",
    "xterm.js",
    "node-pty",
    "websocket",
    "monitoring",
    "dashboard",
    "cli"
  ],
  "author": "Leask Wong",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "@fontsource/monaspace-neon": "^5.2.5",
    "@koa/router": "^15.4.0",
    "@mozilla/readability": "^0.6.0",
    "formidable": "^3.5.4",
    "jsdom": "^29.0.1",
    "koa": "^3.1.2",
    "koa-bodyparser": "^4.4.1",
    "koa-static": "^5.0.0",
    "node-ansiparser": "^2.2.1",
    "node-pty": "^1.1.0",
    "openai": "^6.32.0",
    "utilitas": "^2001.1.135",
    "ws": "^8.20.0",
    "xterm-addon-serialize": "^0.11.0",
    "xterm-headless": "^5.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/leask/tabminal.git"
  },
  "bugs": {
    "url": "https://github.com/leask/tabminal/issues"
  },
  "homepage": "https://github.com/leask/tabminal#readme",
  "devDependencies": {
    "eslint": "^10.1.0"
  }
}
